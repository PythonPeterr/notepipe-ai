# Supabase (get from: Supabase Dashboard → Project Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (get from: console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=

# Fireflies (any random string — must match what you set in Fireflies webhook settings)
FIREFLIES_WEBHOOK_SECRET=

# HubSpot OAuth (get from: developers.hubspot.com → your app)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8000/api/auth/hubspot/callback

# Pipedrive OAuth (get from: developers.pipedrive.com → your app)
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
PIPEDRIVE_REDIRECT_URI=http://localhost:8000/api/auth/pipedrive/callback

# Attio OAuth (get from: app.attio.com → Settings → Developers → your app)
ATTIO_CLIENT_ID=
ATTIO_CLIENT_SECRET=
ATTIO_REDIRECT_URI=http://localhost:8000/api/auth/attio/callback

# Zoho OAuth (get from: api-console.zoho.com → Server-based Application)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:8000/api/auth/zoho/callback

# App
FRONTEND_URL=http://localhost:3000
